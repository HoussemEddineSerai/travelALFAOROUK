# ============================================================================
# Environment configuration
# ============================================================================
# Copy this file to `.env.local` (Vite reads it automatically) and fill in the
# values. NEVER commit real keys.
#
# When deploying to your own server, set these via your process manager or
# container orchestrator. Do not hardcode any of these values in the source.
# ============================================================================

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# "supabase" — use the managed Postgres + Auth + Storage backend (default).
# "http"     — use your own Node.js/Postgres REST API. See src/services/impl/http.ts
#              for the endpoint contract you must implement.
VITE_API_MODE=supabase

# ---------------------------------------------------------------------------
# When VITE_API_MODE=supabase
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT

# ---------------------------------------------------------------------------
# When VITE_API_MODE=http
# ---------------------------------------------------------------------------
# Base URL of your custom REST API (no trailing slash).
VITE_API_BASE_URL=https://api.your-domain.com
